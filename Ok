local function tun()
    loadstring(game:HttpGet("https://raw.githubusercontent.com/kipr987/Test/refs/heads/main/te"))()

    local RunService = game:GetService("RunService")
    local Players = game:GetService("Players")
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local CYCLE_TIME = 5

    local rimid = nil
    local spoilerid = nil
    local heartbeatConn = nil
    local lastHypershift = false
    local lastCar = nil -- отслеживаем последнюю машину
    local driftid = nil

    local function rim(name, car)
        if not ReplicatedStorage.Resource.Rims:FindFirstChild(name) then return end
        rimid = ReplicatedStorage.Resource.Rims:FindFirstChild(name).MeshId
        for i, v in car.Preset:GetChildren() do
            if v:IsA("Model") then
                local hasRim = false
                for i, f in v:GetChildren() do
                    if f.Name == "Rim" and f.MeshId == rimid then
                        hasRim = true
                    elseif f.Name == "Rim" then
                        f:Destroy()
                    end
                end
                if not hasRim and v:FindFirstChild("WheelRoot") then
                    local void = ReplicatedStorage.Resource.Rims[name]:Clone()
                    void.CFrame = v.WheelRoot.CFrame
                    void.Name = "Rim"
                    void.Parent = v
                    void.Anchored = false
                    void.Size = Vector3.new(
                        void.Size.X,
                        v.WheelRoot.Size.Y / 1.3,
                        v.WheelRoot.Size.Z / 1.3
                    )
                    local weld = Instance.new("Weld", void)
                    weld.Part1 = void
                    weld.Part0 = v.WheelRoot
					if v.Name == "WheelBackRight" or v.Name == "WheelFrontRight" then
						weld.C1 = CFrame.Angles(0,math.rad(180),0) * CFrame.new(0 -_G.RimsTable[_G.Rim]/1.5,0,0)
					else
						weld.C1 = CFrame.new(_G.RimsTable[_G.Rim]/1.5,0,0)
					end
                end
            end
        end
    end

    local function spoiler(name, car)
        if not ReplicatedStorage.Resource.Spoiler:FindFirstChild(name) then return end
        if not car:FindFirstChild("Spoiler") then return end
        local hasSpoiler = false
        spoilerid = ReplicatedStorage.Resource.Spoiler:FindFirstChild(name).MeshId
        for i, v in car:GetChildren() do
            if v.Name == "SpoilerPart" and v:IsA("MeshPart") and v.MeshId == spoilerid then
                hasSpoiler = true
            elseif v.Name == "SpoilerPart" then
                v:Destroy()
            end
        end
        if hasSpoiler then return end
        local thr = ReplicatedStorage.Resource.Spoiler[name]:Clone()
        thr.Parent = car
        thr.Name = "SpoilerPart"
        thr.Anchored = false
        local weld = Instance.new("Weld", thr)
        weld.Part1 = thr
        weld.Part0 = car.Spoiler
		weld.C1 = CFrame.new(0,-1,0)
    end

    local function texture(name, car)
        if not _G.TextureId then return end
        if not _G.TextureId[name] then return end
        if not _G.TextureId[name][car.Name] then return end
        car.Model.Body.TextureID = "rbxassetid://" .. _G.TextureId[name][car.Name]
		if car.Model:FindFirstChild("SecondBody") then
			car.Model.SecondBody.TextureID = "rbxassetid://" .. _G.TextureId[name][car.Name]
		end
		if car.Model:FindFirstChild("Wing") then
			car.Model.Wing.Body.TextureID = "rbxassetid://" .. _G.TextureId[name][car.Name]
		end
		if car.Preset:FindFirstChild("Hatch") then
			car.Preset:FindFirstChild("Hatch").InnerModel.Body.TextureID = "rbxassetid://" .. _G.TextureId[name][car.Name]
			car.Preset:FindFirstChild("Hatch").InnerModel.SecondBody.TextureID = "rbxassetid://" .. _G.TextureId[name][car.Name]
		end
    end

    local function applyHypershiftTexturesNoColor(part)
        if not part or not part:IsA("MeshPart") then return end
        for _, normalId in Enum.NormalId:GetEnumItems() do
            if normalId ~= Enum.NormalId.Bottom then
                local texName = "HyperChrome" .. normalId.Name
                if not part:FindFirstChild(texName) then
                    local tex = Instance.new("Texture")
                    tex.Name = texName
                    tex.StudsPerTileU = 55
                    tex.StudsPerTileV = 105
                    tex.Face = normalId
                    tex.Texture = "rbxassetid://11372133369"
                    tex.Parent = part
                end
            end
        end
    end

    local function applyHypershiftTexturesBody(part)
        if not part or not part:IsA("MeshPart") then return end
        part.Color = Color3.new(0, 0, 0)
        for _, normalId in Enum.NormalId:GetEnumItems() do
            if normalId ~= Enum.NormalId.Bottom then
                local texName = "HyperChrome" .. normalId.Name
                if not part:FindFirstChild(texName) then
                    local tex = Instance.new("Texture")
                    tex.Name = texName
                    tex.StudsPerTileU = 55
                    tex.StudsPerTileV = 105
                    tex.Face = normalId
                    tex.Texture = "rbxassetid://11372133369"
                    tex.Parent = part
                end
            end
        end
    end

    local function removeHypershiftTextures(part)
        if not part or not part:IsA("MeshPart") then return end
        for _, child in part:GetChildren() do
            if child:IsA("Texture") and child.Name:sub(1, 11) == "HyperChrome" then
                child:Destroy()
            end
        end
    end

    local function applyHypershiftToAll(car)
        for _, v in car.Preset:GetChildren() do
            if v:IsA("Model") then
                local r = v:FindFirstChild("Rim")
                if r then
                    applyHypershiftTexturesNoColor(r)
                end
            end
        end
        local sp = car:FindFirstChild("SpoilerPart")
        if sp then
            applyHypershiftTexturesNoColor(sp)
        end
        local body = car.Model:FindFirstChild("Body")
        if body then
            car:SetAttribute("HyperChromeAppliedName", "HyperShift")
            applyHypershiftTexturesBody(body)
			if car.Model:FindFirstChild("SecondBody") then
				applyHypershiftTexturesBody(car.Model:FindFirstChild("SecondBody"))
			end
			if car.Model:FindFirstChild("Wing") then
				applyHypershiftTexturesBody(car.Model.Wing.Body)
			end
			if car.Preset:FindFirstChild("Hatch") then
				applyHypershiftTexturesBody(car.Preset:FindFirstChild("Hatch").InnerModel.Body)
				applyHypershiftTexturesBody(car.Preset:FindFirstChild("Hatch").InnerModel.SecondBody)
			end
        end
    end

    local function removeHypershiftFromAll(car)
        for _, v in car.Preset:GetChildren() do
            if v:IsA("Model") then
                local r = v:FindFirstChild("Rim")
                if r then
                    removeHypershiftTextures(r)
                end
            end
        end
        local sp = car:FindFirstChild("SpoilerPart")
        if sp then
            removeHypershiftTextures(sp)
        end
        local body = car.Model:FindFirstChild("Body")
        if body then
            removeHypershiftTextures(body)
            car:SetAttribute("HyperChromeAppliedName", "")
            body.Color = Color3.fromRGB(163, 162, 165)
			if car.Model:FindFirstChild("SecondBody") then
				removeHypershiftTextures(car.Model:FindFirstChild("SecondBody"))
				car.Model:FindFirstChild("SecondBody").Color = Color3.fromRGB(163, 162, 165)
			end
			if car.Model:FindFirstChild("Wing") then
				removeHypershiftTextures(car.Model.Wing.Body)
				car.Model.Wing.Body.Color = Color3.fromRGB(163, 162, 165)
			end
			if car.Preset:FindFirstChild("Hatch") then
				removeHypershiftTextures(car.Preset:FindFirstChild("Hatch").InnerModel.Body)
				car.Preset:FindFirstChild("Hatch").InnerModel.Body.Color = Color3.fromRGB(163, 162, 165)
				removeHypershiftTextures(car.Preset:FindFirstChild("Hatch").InnerModel.SecondBody)
				car.Preset:FindFirstChild("Hatch").InnerModel.SecondBody.Color = Color3.fromRGB(163, 162, 165)
			end
        end
    end

    local function animateHypershiftOnPart(part, rainbowColor)
        if not part or not part:IsA("MeshPart") then return end
        local cam = workspace.CurrentCamera
        local pos = part.Position
        local lookVec = cam.CFrame.LookVector
        local angle = lookVec:Angle(Vector3.new(1, 1, 1))
        local offset = pos.X % 8096 / 8096 + pos.Y % 8096 / 8096 + pos.Z % 8096 / 8096
        local offsetU = (angle + offset * 55) * 10
        local offsetV = (angle + offset * 105) * 10
        for _, child in part:GetChildren() do
            if child:IsA("Texture") and child.Name:sub(1, 11) == "HyperChrome" then
                child.OffsetStudsU = offsetU
                child.OffsetStudsV = offsetV
                child.Color3 = rainbowColor
            end
        end
    end

    local function startHypershiftAnimation()
        if heartbeatConn then return end
        heartbeatConn = RunService.Heartbeat:Connect(function()
            if not _G.tun or not _G.hypershift then return end

            local hue = os.clock() % CYCLE_TIME / CYCLE_TIME
            local rainbowColor = Color3.fromHSV(hue, 0.94, 1)

            for _, v in workspace.Vehicles:GetChildren() do
                if v:FindFirstChild("_VehicleState_" .. Players.LocalPlayer.Name) then
                    for _, wheel in v.Preset:GetChildren() do
                        if wheel:IsA("Model") then
                            local r = wheel:FindFirstChild("Rim")
                            if r then
                                animateHypershiftOnPart(r, rainbowColor)
                            end
                        end
                    end
                    local sp = v:FindFirstChild("SpoilerPart")
                    if sp then
                        animateHypershiftOnPart(sp, rainbowColor)
                    end
                    local body = v.Model:FindFirstChild("Body")
                    if body then
                        animateHypershiftOnPart(body, rainbowColor)
                        if body.Color.R ~= 0 or body.Color.G ~= 0 or body.Color.B ~= 0 then
                            body.Color = Color3.new(0, 0, 0)
                        end

						if v.Model:FindFirstChild("SecondBody") then
							animateHypershiftOnPart(v.Model:FindFirstChild("SecondBody"), rainbowColor)
							if v.Model:FindFirstChild("SecondBody").Color.R ~= 0 or v.Model:FindFirstChild("SecondBody").Color.G ~= 0 or v.Model:FindFirstChild("SecondBody").Color.B ~= 0 then
                            	v.Model:FindFirstChild("SecondBody").Color = Color3.new(0, 0, 0)
                        	end
						end
						if v.Model:FindFirstChild("Wing") then
							animateHypershiftOnPart(v.Model:FindFirstChild("Wing").Body, rainbowColor)
							if v.Model:FindFirstChild("Wing").Body.Color.R ~= 0 or v.Model:FindFirstChild("Wing").Body.Color.G ~= 0 or v.Model:FindFirstChild("Wing").Body.Color.B ~= 0 then
                            	v.Model:FindFirstChild("Wing").Body.Color = Color3.new(0, 0, 0)
                        	end
						end
						if v.Preset:FindFirstChild("Hatch") then
							animateHypershiftOnPart(v.Preset:FindFirstChild("Hatch").InnerModel.Body, rainbowColor)
							if v.Preset:FindFirstChild("Hatch").InnerModel.Body.Color.R ~= 0 or v.Preset:FindFirstChild("Hatch").InnerModel.Body.Color.G ~= 0 or v.Preset:FindFirstChild("Hatch").InnerModel.Body.Color.B ~= 0 then
								v.Preset:FindFirstChild("Hatch").InnerModel.Body.Color = Color3.new(0, 0, 0)
                        	end
							animateHypershiftOnPart(v.Preset:FindFirstChild("Hatch").InnerModel.SecondBody, rainbowColor)
							if v.Preset:FindFirstChild("Hatch").InnerModel.SecondBody.Color.R ~= 0 or v.Preset:FindFirstChild("Hatch").InnerModel.SecondBody.Color.G ~= 0 or v.Preset:FindFirstChild("Hatch").InnerModel.SecondBody.Color.B ~= 0 then
								v.Preset:FindFirstChild("Hatch").InnerModel.SecondBody.Color = Color3.new(0, 0, 0)
                        	end
						end
                    end
                    break
                end
            end
        end)
    end

    local function stopHypershiftAnimation()
        if heartbeatConn then
            heartbeatConn:Disconnect()
            heartbeatConn = nil
        end
    end

    local function drift(name, car)
        if not game:GetService("ReplicatedStorage").Resource.DriftParticles:FindFirstChild(name) then return end
        if not car:FindFirstChild("Spoiler") then return end
        local drift = false
        driftid = game:GetService("ReplicatedStorage").Resource.DriftParticles:FindFirstChild(name):GetChildren()[1].Texture
        for i, v in car.Preset:GetChildren() do
            if v.Name == "Drift" then
                for i, f in v:GetChildren() do
                    if f.Texture == driftid then
                        drift = true
                    else
                        f:Destroy()
                    end
                end
            end
        end
        if not drift then
            for i, v in car.Preset:GetChildren() do
                if v.Name == "Drift" then
                    local dr = game:GetService("ReplicatedStorage").Resource.DriftParticles:FindFirstChild(name):GetChildren()[1]:Clone()
                    dr.Parent = v
                    dr.Enabled = false
                    car:GetAttributeChangedSignal("VehicleIsDriver"):Connect(function()
                        if car:GetAttribute("VehicleIsDriver") then
                            dr.Enabled = true
                        else
                            dr.Enabled = false
                        end
                    end)
                end
            end
        end
    end

    while wait() and _G.tun do
        local car = nil
        for i, v in workspace.Vehicles:GetChildren() do
            if v:FindFirstChild("_VehicleState_" .. Players.LocalPlayer.Name) then
                car = v
                _G.CarObj = v
                break
            end
        end

        if car then
            rim(_G.Rim, car)
            drift(_G.Dr, car)
            spoiler(_G.Sp, car)
            texture(_G.Txt, car)

            -- если сменилась машина — сбрасываем lastHypershift
            -- чтобы hypershift применился заново к новой машине
            if lastCar ~= car then
                lastCar = car
                lastHypershift = not _G.hypershift -- форсируем переприменение
            end

            if _G.hypershift ~= lastHypershift then
                lastHypershift = _G.hypershift
                if _G.hypershift then
                    applyHypershiftToAll(car)
                    startHypershiftAnimation()
                else
                    stopHypershiftAnimation()
                    removeHypershiftFromAll(car)
                end
            end
        else
            -- вышли из машины — сбрасываем
            if lastCar ~= nil then
                lastCar = nil
                lastHypershift = false
                stopHypershiftAnimation()
            end
        end
    end
    stopHypershiftAnimation()
end
_G.CarObj = nil
_G.Rim = saves.rim
_G.Sp = saves.spoiler
_G.Dr = saves.drift
_G.Txt = saves.texture
if _G.tun then
	spawn(function()
    	tun()
	end)
end
