local function checkAboveHead(checkPos, ignoreList)
	local startPos = checkPos + Vector3.new(0, 5, 0)
	local direction = Vector3.new(0, 300, 0)
	local raycastParams = RaycastParams.new()
	raycastParams.FilterDescendantsInstances = ignoreList or {}
	raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
	return workspace:Raycast(startPos, direction, raycastParams)
end

local function getPosition(target)
	if typeof(target) == "Vector3" then
		return target
	elseif typeof(target) == "Instance" then
		if target:IsA("Model") then
			local primary = target:FindFirstChild("HumanoidRootPart") or target:FindFirstChild("PrimaryPart") or target:FindFirstChildWhichIsA("BasePart")
			if primary then
				return primary.Position
			end
		elseif target:IsA("BasePart") then
			return target.Position
		end
	end
	return nil
end

function tp(target)
	local player = game:GetService("Players").LocalPlayer
	local character = player.Character
	if not character then return end

	local hrp = character:WaitForChild("HumanoidRootPart")
	if checkAboveHead(hrp.Position, {character}) then return end
	if tpf then return end

	tpf = true

	local bv = Instance.new("BodyVelocity")
	bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
	bv.Velocity = Vector3.zero
	bv.Parent = hrp

	local function moveTo(targetPos, moveSpeed)
		local direction = (targetPos - hrp.Position).Unit
		bv.Velocity = direction * moveSpeed
		repeat
			task.wait()
		until (targetPos - hrp.Position).Magnitude <= 25
		bv.Velocity = Vector3.zero
	end

	local function moveToObjectHeight(dynamicTarget, height, moveSpeed)
		bv.Velocity = Vector3.zero
		repeat
			local currentPos = getPosition(dynamicTarget)
			if not currentPos then break end
			local targetPos = Vector3.new(currentPos.X, height, currentPos.Z)
			local direction = (targetPos - hrp.Position).Unit
			local distance = (targetPos - hrp.Position).Magnitude
			if distance <= 25 then
				bv.Velocity = Vector3.zero
				break
			end
			bv.Velocity = direction * moveSpeed
			task.wait()
		until false
		bv.Velocity = Vector3.zero
	end

	local function getVehicle(targetPos)
		if character:GetAttribute("InVehicle") then return nil end
		local py = hrp.Position.Y
		local args = {"Chassis", "Camaro"}
		game:GetService("ReplicatedStorage"):WaitForChild("GarageSpawnVehicle"):FireServer(unpack(args))
		wait(1)
		if character:GetAttribute("InVehicle") then return end
		if game:GetService("Players").LocalPlayer.TeamColor == BrickColor.new("Bright orange") then
			moveTo(Vector3.new(hrp.Position.X, 300, hrp.Position.Z), 100)
			moveTo(Vector3.new(hrp.Position.X, py, hrp.Position.Z), 100)
			wait(.2)
			bv:Destroy()
			hrp.CFrame = CFrame.new(Vector3.new(hrp.Position.X, py, hrp.Position.Z))
			wait(.3)
			local args = {"Chassis", "Camaro"}
			game:GetService("ReplicatedStorage"):WaitForChild("GarageSpawnVehicle"):FireServer(unpack(args))
			wait(1)
			bv = Instance.new("BodyVelocity")
			bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
			bv.Velocity = Vector3.zero
			bv.Parent = hrp
		end
		if character:GetAttribute("InVehicle") then return end
		local vehicles = {}
		for _, v in workspace.Vehicles:GetChildren() do
			if v.Name == "Camaro" and not v:GetAttribute("TeamRestrict") and v:FindFirstChild("Seat") and (not v:GetAttribute("VehicleHasDriver") or v:GetAttribute("VehicleHasDriver") == false) then
				local seatPos = v.Seat.Position
				if not checkAboveHead(seatPos, {character, v}) then
					table.insert(vehicles, {vehicle = v, dist = (seatPos - hrp.Position).Magnitude})
				end
			end
		end

		if #vehicles == 0 then return nil end

		table.sort(vehicles, function(a, b) return a.dist < b.dist end)

		local nearest = vehicles[1]
		local playerDist = (targetPos - hrp.Position).Magnitude

		if playerDist <= nearest.dist then return nil end

		local seatPos = nearest.vehicle.Seat.Position
		local s = nearest.vehicle.Seat
		print((nearest.vehicle.Seat.Position - hrp.Position).magnitude)
		if (nearest.vehicle.Seat.Position - hrp.Position).magnitude <= 20 then
			hrp.CFrame = CFrame.new(seatPos + s.CFrame.RightVector * -5)
		else
			moveTo(Vector3.new(hrp.Position.X, 300, hrp.Position.Z), 100)
			moveTo(Vector3.new(seatPos.X, 300, seatPos.Z), 100)
			moveTo(seatPos, 100)
			hrp.CFrame = CFrame.new(seatPos + s.CFrame.RightVector * -5)
		end

		task.wait(0.2)
		bv:Destroy()

		repeat
			game:GetService("VirtualInputManager"):SendKeyEvent(true, Enum.KeyCode.E.Value, false, nil)
			task.wait()
			game:GetService("VirtualInputManager"):SendKeyEvent(false, Enum.KeyCode.E.Value, false, nil)
