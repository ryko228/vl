function onCharacterAdded(character)
	wait(1)
	if character then
		local humanoidRootPart = character:WaitForChild('HumanoidRootPart')
		for i, v in game:GetService("Players").LocalPlayer.Character:GetChildren() do
			if v:IsA("BasePart") and v.Name ~= "HumanoidRootPart" then
				v.CanTouch = not _G.Lasers
			end
		end
		if _G.Ragdoll then
			humanoidRootPart:AddTag('NoFallDamage')
			humanoidRootPart:AddTag('NoRagdoll')
		else
			humanoidRootPart:RemoveTag('NoFallDamage')
			humanoidRootPart:RemoveTag('NoRagdoll')
		end
	end
	local run = nil
	run = game:GetService("RunService").RenderStepped:Connect(function()
		if _G.Lasers then
			pcall(function()
				workspace.Museum.Lights:Destroy()
				for i, v in workspace.RobberyTomb.SpikeRoom.Spikes:GetDescendants() do
					if v.Name == "Spikes" or v.Name == "Door" then
						v:Destroy()
					end
				end
				workspace.MilitaryBase.Forcefield:Destroy()
			end)
		else
			run:Disconnect()
		end
	end)
end

