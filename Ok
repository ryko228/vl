	speed = character:GetAttribute("InVehicle") and 450 or 100

	if isDynamic then
		bv.Velocity = Vector3.zero
		repeat
			local currentPos = getPosition(target)
			if not currentPos then break end
			local direction = (currentPos - hrp.Position).Unit
			local distance = (currentPos - hrp.Position).Magnitude
			if distance <= 15 then
