local function value(v)
	if v:FindFirstChild("Title") then
		local cash = v.Title.Text:Clone()
		cash.Parent = v.Title
		cash.Name = "Cash"
		cash.Position = UDim2.new(0.5, 0, 1.5, 0)
		cash.Size = UDim2.new(1, 0, .7, 0)
		local stroke = Instance.new("UIStroke",cash)
		stroke.Thickness = 1
		local item = 0
		if v:FindFirstChild("Title") then
			local itemName = v:FindFirstChild("Title").Text.Text
			local foundKey, foundVal, matchType = findItem(itemName, values[v.Category.Text.Text])
			if foundKey then
				if matchType ~= "exact" then
					print("P1 fuzzy match:", itemName, "→", foundKey, "(", matchType, ")")
				end
				item += foundVal
			end
		end
		cash.Text = formatNumber(item)
		cash.TextColor3 = Color3.new(0.478431, 1, 0.396078)
	end
end


game:GetService("Players").LocalPlayer.PlayerGui.AppUI.ChildAdded:Connect(function(child)
	if child.Name == "Trade" and child:FindFirstChild("ItemsContainer") then
		for i, v in game:GetService("Players").LocalPlayer.PlayerGui.AppUI.Trade.ItemsContainer.ScrollingGrid:GetChildren() do
			if v:IsA("TextButton") then
				value(v)
			end
		end
		game:GetService("Players").LocalPlayer.PlayerGui.AppUI.Trade.ItemsContainer.ScrollingGrid.ChildAdded:Connect(function(child)
			value(child)
		end)
	end
